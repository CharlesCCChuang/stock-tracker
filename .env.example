# ============================================
# 美股追蹤網站 — API 金鑰設定範本
# 使用方式：複製這個檔案改名為 .env，把鑰匙貼進引號後面
# .env 已列入 .gitignore，永遠不會被上傳
# ============================================

# Finnhub（股價 / 新聞 / 財報日曆）— https://finnhub.io 註冊後在 Dashboard 拿
FINNHUB_API_KEY=

# Google Gemini（AI 分析）— https://aistudio.google.com → Get API key
GEMINI_API_KEY=

# Telegram Bot（即時通知）— Telegram 找 @BotFather → /newbot 拿 token
TELEGRAM_BOT_TOKEN=
# 你自己的 chat id（bot 建好後我幫你查）
TELEGRAM_CHAT_ID=

# Gmail 通知用（之後 Phase 7 才需要，先留空）
GMAIL_APP_PASSWORD=
